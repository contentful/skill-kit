---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

interface NavItem {
  label: string;
  href: string;
}

interface NavSection {
  title: string;
  items: NavItem[];
}

const sections: NavSection[] = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Overview', href: `${base}getting-started/` },
      { label: 'Testing', href: `${base}getting-started/testing/` },
      { label: 'Building', href: `${base}getting-started/building/` },
    ],
  },
  {
    title: 'Guides',
    items: [
      { label: 'Workflow Skills', href: `${base}guides/workflow-skills/` },
      { label: 'Reference Skills', href: `${base}guides/reference-skills/` },
      { label: 'Modules', href: `${base}guides/modules/` },
      { label: 'Primitives', href: `${base}guides/primitives/` },
    ],
  },
  {
    title: 'Reference',
    items: [
      { label: 'API', href: `${base}api/` },
      { label: 'Architecture', href: `${base}architecture/` },
    ],
  },
  {
    title: 'Examples',
    items: [
      { label: 'Overview', href: `${base}examples/` },
      { label: 'get-to-know-you', href: `${base}examples/get-to-know-you/` },
      { label: 'ts-patterns', href: `${base}examples/ts-patterns/` },
    ],
  },
];

function isActive(href: string) {
  return currentPath === href || currentPath === href.slice(0, -1);
}
---

<aside class="sidebar">
  <nav class="sidebar-nav" aria-label="Documentation">
    {
      sections.map((section) => (
        <div class="sidebar-section">
          <h3 class="sidebar-heading">{section.title}</h3>
          <ul class="sidebar-list">
            {section.items.map((item) => (
              <li>
                <a href={item.href} class:list={['sidebar-link', { active: isActive(item.href) }]}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-5));
    align-self: start;
    width: var(--sidebar-width);
    max-height: calc(100vh - var(--nav-height) - var(--space-8));
    overflow-y: auto;
    padding-right: var(--space-5);
  }

  .sidebar-section {
    margin-bottom: var(--space-5);
  }

  .sidebar-heading {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
    padding-left: var(--space-3);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-list li {
    margin: 0;
  }

  .sidebar-link {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border-left: 2px solid transparent;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .sidebar-link:hover {
    color: var(--color-accent-bright);
    background: var(--color-bg-inset);
  }

  .sidebar-link.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background: var(--color-accent-glow);
  }
</style>
